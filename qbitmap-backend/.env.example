# QBitmap Backend Environment Variables
# Copy this file to .env and fill in the values

# ==================== Server ====================
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ==================== Authentication ====================
# JWT Secret (generate a strong random string)
# Example: openssl rand -base64 32
JWT_SECRET=

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Device Authentication
DEVICE_SHARED_SECRET=

# Frontend URL
FRONTEND_URL=https://qbitmap.com

# ==================== MediaMTX / RTCGateway ====================
# MediaMTX server hostname
MEDIAMTX_HOST=YOUR_MEDIAMTX_SERVER_IP
MEDIAMTX_SERVER=YOUR_MEDIAMTX_SERVER_IP

# MediaMTX API endpoint
MEDIAMTX_API=http://YOUR_MEDIAMTX_SERVER_IP:9997

# MediaMTX WHEP base URL (WebRTC streaming)
MEDIAMTX_WHEP_BASE=http://YOUR_MEDIAMTX_SERVER_IP:8889

# MediaMTX Playback server
MEDIAMTX_PLAYBACK=http://YOUR_MEDIAMTX_SERVER_IP:9996

# MediaMTX Metrics endpoint
MEDIAMTX_METRICS=http://YOUR_MEDIAMTX_SERVER_IP:9998

# Allowed WHEP hosts (comma-separated, for SSRF protection)
ALLOWED_WHEP_HOSTS=YOUR_MEDIAMTX_SERVER_IP

# ==================== ONVIF / Camera Services ====================
# ONVIF Events service URL
ONVIF_SERVICE_URL=http://YOUR_SERVER_IP:3003

# RTSP Capture service URL
CAPTURE_SERVICE_URL=http://YOUR_SERVER_IP:3002

# ==================== AI Services ====================
# AI/LLM service URL (Ollama)
AI_HOST=YOUR_AI_SERVER_IP
AI_SERVICE_URL=http://YOUR_AI_SERVER_IP:11434

# ==================== Face Recognition ====================
FACE_API_URL=https://matcher.qbitwise.com
FACE_API_USERNAME=
FACE_API_PASSWORD=

# ==================== Voice Call ====================
VOICE_HOST=YOUR_VOICE_SERVER_IP
ENTANGLE_API_URL=http://YOUR_VOICE_SERVER_IP:8000
ENTANGLE_API_TOKEN=
MATRIX_ROOM_ID=
MATRIX_TARGET_USER=

# ==================== Health Check Hosts ====================
QBITMAP_HOST=YOUR_QBITMAP_HOST_IP
